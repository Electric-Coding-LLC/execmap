{
  "name": "@electric_coding/execmap",
  "version": "0.4.0",
  "description": "A lightweight planning system for bounded execution maps.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Electric-Coding-LLC/execmap.git"
  },
  "homepage": "https://github.com/Electric-Coding-LLC/execmap#readme",
  "bugs": {
    "url": "https://github.com/Electric-Coding-LLC/execmap/issues"
  },
  "keywords": [
    "agent",
    "cli",
    "execmap",
    "markdown",
    "planning"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "docs",
    "examples",
    "skills",
    "src",
    "templates",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "execmap": "./src/cli.ts"
  },
  "scripts": {
    "check": "bun run typecheck && bun test && bun run check:example && bun run check:packed-install",
    "pack:dry-run": "npm pack --dry-run --ignore-scripts",
    "release": "bun tools/release-package.ts",
    "typecheck": "tsc --noEmit",
    "check:example": "bun run src/cli.ts check examples/portable-package-release",
    "check:packed-install": "bun run tools/smoke-packed-install.ts",
    "next:example": "bun run src/cli.ts next examples/portable-package-release",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.3"
  }
}
